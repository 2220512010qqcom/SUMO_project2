<nodes>
    <!-- 创建 2x2 网格的4个交叉路口 -->
    <node id="1" x="0.0" y="0.0" type="traffic_light"/>
    <node id="2" x="0.0" y="250.0" type="traffic_light"/>
    <node id="3" x="250.0" y="0.0" type="traffic_light"/>
    <node id="4" x="250.0" y="250.0" type="traffic_light"/>
    
    <!-- 边界节点（用于生成车流） -->
    <node id="north1" x="0.0" y="250.0" type="priority"/>
    <node id="north2" x="250.0" y="250.0" type="priority"/>
    <node id="south1" x="0.0" y="-250.0" type="priority"/>
    <node id="south2" x="250.0" y="-250.0" type="priority"/>
    <node id="east1" x="250.0" y="0.0" type="priority"/>
    <node id="east2" x="250.0" y="250.0" type="priority"/>
    <node id="west1" x="-250.0" y="0.0" type="priority"/>
    <node id="west2" x="-250.0" y="250.0" type="priority"/>
</nodes>